# Alibaba Cloud DashScope (Qwen3 / QwQ / Qwen2.5 series)
# Get your key at: https://bailian.console.aliyuncs.com
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# Optional: set Chinese domestic endpoint (international is default)
# DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# OpenRouter (alternative routing — not required for DashScope)
# OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here
# OPENAI_API_BASE=https://openrouter.ai/api/v1
